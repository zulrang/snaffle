{
  "name": "@orchestrator/spine",
  "version": "0.0.0",
  "description": "Snaffle — deterministic agent delivery pipeline. External control-plane spine that drives stochastic agents over Pi; models only where intent is irreducible.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=22.0.0"
  },
  "module": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./domain": "./src/domain/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test src",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "check": "bun run typecheck && bun run lint && bun run guard:bun-native && bun run guard:name-branching && bun run test",
    "check:node": "npm run typecheck && npm run lint && npm run guard:bun-native && npm run guard:name-branching && npm run test:node-smoke",
    "guard:bun-native": "node scripts/guard-no-bun-native.mjs",
    "guard:name-branching": "node scripts/guard-name-branching.mjs",
    "test:node-smoke": "node --test scripts/node-smoke-check.mjs",
    "orchestrator": "bun src/cli.ts"
  },
  "bin": {
    "orchestrator": "./src/cli.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.9.3",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "0.74.0",
    "@earendil-works/pi-ai": "0.74.0",
    "@earendil-works/pi-coding-agent": "0.74.0",
    "better-sqlite3": "^12.11.1",
    "smol-toml": "^1.6.1"
  }
}
